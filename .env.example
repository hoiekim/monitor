# Required
DISCORD_ALARM_WEBHOOK=https://discord.com/api/webhooks/...
LOG_SERVER_TOKEN=your-secret-token-here
MONITOR_TARGETS=inbox,budget          # comma-separated Docker container names

# Optional (defaults shown)
LOG_PORT=9000
HEALTH_POLL_INTERVAL_MS=60000         # 60s
HEALTH_FAIL_THRESHOLD=1               # alarms on first failure
ALARM_COOLDOWN_MS=60000               # 1 min between alarms for same type+service
DOCKER_SOCKET=/var/run/docker.sock
